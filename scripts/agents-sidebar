#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SIDEBAR_SCRIPT="$SCRIPT_DIR/agents-sidebar.py"

DEFAULT_AGENT_ORDER="orch plan impl review docs"
DEFAULT_SIDEBAR_WIDTH="45"
MIN_SIDEBAR_WIDTH="20"
MIN_MAIN_PANE_WIDTH="35"
DEFAULT_WIDE_WINDOW_NAME="agents-sidebar"
DEFAULT_DONE_TTL="20"
BRANCH_CACHE_TTL="2"
AUTO_COMPACT_DEBOUNCE_SECONDS="0.4"
DELIM=$'\x1f'
HOST_FULL="$(hostname 2>/dev/null || true)"
HOST_SHORT="$(hostname -s 2>/dev/null || true)"
declare -Ag GIT_BRANCH_CACHE=()
declare -Ag ENTRY_LABEL_CACHE=()
declare -Ag ENTRY_LABEL_MODE_CACHE=()
declare -Ag ENTRY_KIND_CACHE=()
declare -Ag ENTRY_PROVIDER_CACHE=()
declare -Ag ENTRY_STATUS_CACHE=()
declare -Ag ENTRY_STATUS_TEXT_CACHE=()
declare -Ag ENTRY_LAST_DONE_CACHE=()
declare -Ag ENTRY_BRANCH_VALUE_CACHE=()
declare -Ag ENTRY_BRANCH_PATH_CACHE=()
declare -Ag ENTRY_BRANCH_CHECKED_CACHE=()
SESSION_METADATA_CACHE_LOADED=0

clear_pending_auto_compact() {
  [[ -n "${SESSION_ID:-}" ]] || return 0
  unset_option @agents_sidebar_pending_auto_compact
  unset_option @agents_sidebar_pending_auto_compact_token
  unset_option @agents_sidebar_pending_auto_compact_client
}

fail() {
  local message="agents-sidebar: $*"
  if [[ -n "${SESSION_ID:-}" ]] && command -v tmux >/dev/null 2>&1; then
    unset_option @agents_sidebar_transition
    clear_pending_auto_compact
    release_mode_transition_lock
    release_repair_lock
  fi
  echo "$message" >&2
  if [[ "${AGENTS_SIDEBAR_NOTIFY:-0}" == "1" ]] && command -v tmux >/dev/null 2>&1; then
    local target="${AGENTS_SIDEBAR_PANE:-${TMUX_PANE:-}}"
    if [[ -n "$target" ]]; then
      tmux display-message -d 5000 -t "$target" "$message" 2>/dev/null || true
    else
      tmux display-message -d 5000 "$message" 2>/dev/null || true
    fi
  fi
  exit 1
}

tmux_available() {
  command -v tmux >/dev/null 2>&1
}

current_client_field() {
  local field="$1"
  local tty="${AGENTS_SIDEBAR_CLIENT_TTY:-}"
  local client_tty session_id window_id pane_id result=""
  [[ -n "$tty" ]] || return 1

  while IFS="$DELIM" read -r client_tty session_id window_id pane_id; do
    [[ "$client_tty" == "$tty" ]] || continue
    case "$field" in
      session_id)
        result="$session_id"
        ;;
      window_id)
        result="$window_id"
        ;;
      pane_id)
        result="$pane_id"
        ;;
    esac
  done < <(tmux list-clients -F "#{client_tty}${DELIM}#{session_id}${DELIM}#{window_id}${DELIM}#{pane_id}" 2>/dev/null || true)

  [[ -n "$result" ]] || return 1
  echo "$result"
}

current_session_id() {
  local target_pane client_session
  target_pane="${AGENTS_SIDEBAR_PANE:-${TMUX_PANE:-}}"
  if [[ -n "$target_pane" ]]; then
    tmux display-message -p -t "$target_pane" '#{session_id}'
  else
    client_session="$(current_client_field session_id)"
    if [[ -n "$client_session" ]]; then
      echo "$client_session"
    else
      tmux display-message -p '#{session_id}'
    fi
  fi
}

SESSION_ID=""

init_session() {
  tmux_available || fail "tmux is not installed"
  if [[ -n "${AGENTS_SIDEBAR_SESSION:-}" ]]; then
    SESSION_ID="$AGENTS_SIDEBAR_SESSION"
  elif [[ -n "${TMUX:-}" || -n "${TMUX_PANE:-}" || -n "${AGENTS_SIDEBAR_PANE:-}" ]]; then
    SESSION_ID="$(current_session_id)"
  else
    fail "must be run inside tmux or with AGENTS_SIDEBAR_SESSION set"
  fi
}

get_option() {
  local name="$1"
  local value
  value="$(tmux show-option -qv -t "$SESSION_ID" "$name" 2>/dev/null || true)"
  if [[ -z "$value" ]]; then
    value="$(tmux show-option -gqv "$name" 2>/dev/null || true)"
  fi
  echo "$value"
}

set_option() {
  tmux set-option -q -t "$SESSION_ID" "$1" "$2"
}

unset_option() {
  tmux set-option -qu -t "$SESSION_ID" "$1" 2>/dev/null || true
}

bump_epoch() {
  local current next
  current="$(get_option @agents_sidebar_epoch)"
  current="${current:-0}"
  next=$((current + 1))
  set_option @agents_sidebar_epoch "$next"
}

remember_sidebar_width() {
  local pane_id="${1:-$(get_option @agents_sidebar_pane)}"
  local width title

  if [[ -n "$pane_id" ]] && pane_exists "$pane_id"; then
    title="$(tmux display-message -p -t "$pane_id" '#{pane_title}' 2>/dev/null || true)"
    [[ "$title" == "__agents_sidebar_nav" ]] || return 0
    width="$(tmux display-message -p -t "$pane_id" '#{pane_width}' 2>/dev/null || true)"
    if [[ "$width" =~ ^[0-9]+$ && "$width" -ge "$MIN_SIDEBAR_WIDTH" ]]; then
      set_option @agents_sidebar_width "$width"
    fi
  fi
}

sidebar_width() {
  local target="${1:-}"
  local value pane_id window_width max_allowed fallback

  value="$(get_option @agents_sidebar_width)"
  pane_id="$(get_option @agents_sidebar_pane)"
  if [[ -z "$value" && -n "$pane_id" ]] && pane_exists "$pane_id"; then
    value="$(tmux display-message -p -t "$pane_id" '#{pane_width}' 2>/dev/null || true)"
  fi

  if [[ -n "$target" ]]; then
    window_width="$(tmux display-message -p -t "$target" '#{window_width}' 2>/dev/null || true)"
    if [[ "$window_width" =~ ^[0-9]+$ && "$window_width" -gt 0 ]]; then
      max_allowed=$((window_width - MIN_MAIN_PANE_WIDTH))
      if (( max_allowed < MIN_SIDEBAR_WIDTH )); then
        max_allowed=$MIN_SIDEBAR_WIDTH
      fi
      fallback="$DEFAULT_SIDEBAR_WIDTH"
      if (( fallback > max_allowed )); then
        fallback="$max_allowed"
      fi

      if [[ "$value" =~ ^[0-9]+$ ]] && (( value >= MIN_SIDEBAR_WIDTH && value <= max_allowed )); then
        echo "$value"
        return 0
      fi

      set_option @agents_sidebar_width "$fallback"
      echo "$fallback"
      return 0
    fi
  fi

  if [[ "$value" =~ ^[0-9]+$ && "$value" -ge "$MIN_SIDEBAR_WIDTH" ]]; then
    echo "$value"
    return 0
  fi

  echo "$DEFAULT_SIDEBAR_WIDTH"
}

wide_window_name_default() {
  local value
  value="$(get_option @agents_sidebar_wide_window_name_default)"
  echo "${value:-$DEFAULT_WIDE_WINDOW_NAME}"
}

agent_order_string() {
  local value
  value="$(get_option @agents_sidebar_order)"
  echo "${value:-$DEFAULT_AGENT_ORDER}"
}

done_status_ttl() {
  local value
  value="$(get_option @agents_sidebar_done_ttl)"
  echo "${value:-$DEFAULT_DONE_TTL}"
}

auto_compact_on_narrow() {
  local value
  value="$(get_option @agents_sidebar_auto_compact_on_narrow)"
  echo "${value:-1}"
}

auto_compact_width() {
  local value
  value="$(get_option @agents_sidebar_auto_compact_width)"
  echo "${value:-180}"
}

option_is_enabled() {
  local value="${1,,}"
  [[ "$value" == "1" || "$value" == "on" || "$value" == "yes" || "$value" == "true" ]]
}

is_internal_window_name() {
  local name="$1"
  [[ "$name" == "__agents_sidebar_compact" || "$name" == "__agents_sidebar_pool" || "$name" == "$(store_window_name)" ]]
}

is_internal_pane_title() {
  local title="$1"
  [[ "$title" == __agents_sidebar_* ]]
}

pane_exists() {
  local pane_id="$1"
  local existing_pane
  [[ -n "$pane_id" ]] || return 1

  while IFS= read -r existing_pane; do
    [[ "$existing_pane" == "$pane_id" ]] && return 0
  done < <(tmux list-panes -a -F '#{pane_id}' 2>/dev/null || true)

  return 1
}

window_exists() {
  local window_id="$1"
  local existing_window
  [[ -n "$window_id" ]] || return 1

  while IFS= read -r existing_window; do
    [[ "$existing_window" == "$window_id" ]] && return 0
  done < <(tmux list-windows -a -F '#{window_id}' 2>/dev/null || true)

  return 1
}

pane_is_dead() {
  local pane_id="$1"
  [[ "$(tmux display-message -p -t "$pane_id" '#{pane_dead}' 2>/dev/null || echo 1)" == "1" ]]
}

current_pane_id() {
  local client_pane
  if [[ -n "${AGENTS_SIDEBAR_PANE:-}" ]]; then
    echo "$AGENTS_SIDEBAR_PANE"
  elif [[ -n "${TMUX_PANE:-}" ]]; then
    echo "$TMUX_PANE"
  else
    client_pane="$(current_client_field pane_id)"
    if [[ -n "$client_pane" ]]; then
      echo "$client_pane"
    else
      tmux display-message -p '#{pane_id}'
    fi
  fi
}

current_window_id() {
  local client_window
  if [[ -n "${AGENTS_SIDEBAR_WINDOW:-}" ]]; then
    echo "$AGENTS_SIDEBAR_WINDOW"
  else
    client_window="$(current_client_field window_id)"
    if [[ -n "$client_window" ]]; then
      echo "$client_window"
    else
      tmux display-message -p -t "$(current_pane_id)" '#{window_id}'
    fi
  fi
}

current_window_name() {
  tmux display-message -p -t "$(current_window_id)" '#{window_name}'
}

pane_session_id() {
  tmux display-message -p -t "$1" '#{session_id}'
}

pane_window_id() {
  tmux display-message -p -t "$1" '#{window_id}'
}

session_name_by_id() {
  local target_session="$1"
  local session_id session_name match=""

  while IFS="$DELIM" read -r session_id session_name; do
    if [[ -z "$match" && "$session_id" == "$target_session" ]]; then
      match="$session_name"
    fi
  done < <(tmux list-sessions -F "#{session_id}${DELIM}#{session_name}" 2>/dev/null || true)

  echo "$match"
}

window_name_by_id() {
  local target_window="$1"
  local window_id window_name match=""

  while IFS="$DELIM" read -r window_id window_name; do
    if [[ -z "$match" && "$window_id" == "$target_window" ]]; then
      match="$window_name"
    fi
  done < <(tmux list-windows -a -F "#{window_id}${DELIM}#{window_name}" 2>/dev/null || true)

  echo "$match"
}

window_session_id() {
  local target_window="$1"
  local window_id session_id match=""

  while IFS="$DELIM" read -r window_id session_id; do
    if [[ -z "$match" && "$window_id" == "$target_window" ]]; then
      match="$session_id"
    fi
  done < <(tmux list-windows -a -F "#{window_id}${DELIM}#{session_id}" 2>/dev/null || true)

  echo "$match"
}

pane_option() {
  local pane_id="$1"
  local option_name="$2"
  tmux show-option -pqv -t "$pane_id" "$option_name" 2>/dev/null || true
}

window_layout_string() {
  tmux display-message -p -t "$1" '#{window_layout}'
}

window_active_pane_id() {
  tmux display-message -p -t "$1" '#{pane_id}'
}

session_exists() {
  local session_id="$1"
  [[ -n "$session_id" ]] || return 1
  tmux has-session -t "$session_id" 2>/dev/null
}

session_client_count() {
  local count
  count="$(tmux list-clients -t "$SESSION_ID" -F '#{client_tty}' 2>/dev/null | wc -l | tr -d ' ' || true)"
  echo "${count:-0}"
}

current_client_tty() {
  local tty="${AGENTS_SIDEBAR_CLIENT_TTY:-}"
  if [[ -n "$tty" ]]; then
    echo "$tty"
    return 0
  fi

  tty="$(get_option @agents_sidebar_auto_mode_client)"
  if [[ -n "$tty" ]]; then
    echo "$tty"
    return 0
  fi

  if [[ "$(session_client_count)" == "1" ]]; then
    local first_tty=""
    while IFS= read -r tty; do
      [[ -n "$first_tty" ]] || first_tty="$tty"
    done < <(tmux list-clients -t "$SESSION_ID" -F '#{client_tty}' 2>/dev/null || true)
    echo "$first_tty"
  fi
}

current_client_width() {
  local tty width
  tty="$(current_client_tty)"
  if [[ -n "$tty" ]]; then
    local client_tty
    while IFS="$DELIM" read -r client_tty width; do
      [[ "$client_tty" == "$tty" ]] || continue
    done < <(tmux list-clients -t "$SESSION_ID" -F "#{client_tty}${DELIM}#{client_width}" 2>/dev/null || true)
    if [[ "$width" =~ ^[0-9]+$ ]]; then
      echo "$width"
      return 0
    fi
  fi

  if [[ "$(session_client_count)" == "1" ]]; then
    local first_width=""
    while IFS= read -r width; do
      [[ -n "$first_width" ]] || first_width="$width"
    done < <(tmux list-clients -t "$SESSION_ID" -F '#{client_width}' 2>/dev/null || true)
    echo "$first_width"
  fi
}

managed_pane_ids_in_window() {
  local window_id="$1"
  tmux list-panes -t "$window_id" -F "#{pane_id}${DELIM}#{pane_title}" 2>/dev/null | awk -F "$DELIM" '$2 !~ /^__agents_sidebar_/ { print $1 }' | paste -sd ' ' -
}

window_has_internal_sidebar_panes() {
  local window_id="$1"
  local title found=1

  found=1
  while IFS= read -r title; do
    if [[ "$title" == __agents_sidebar_* ]]; then
      found=0
    fi
  done < <(tmux list-panes -t "$window_id" -F '#{pane_title}' 2>/dev/null || true)

  return "$found"
}

saved_wide_layout_exists() {
  [[ -n "$(get_option @agents_sidebar_wide_layout)" ]]
}

mark_wide_layout_dirty() {
  set_option @agents_sidebar_wide_layout_dirty 1
}

clear_wide_layout_dirty() {
  set_option @agents_sidebar_wide_layout_dirty 0
}

saved_wide_layout_dirty() {
  [[ "$(get_option @agents_sidebar_wide_layout_dirty)" == "1" ]]
}

save_wide_layout() {
  local mode window_id window_name pane_ids layout active_pane
  mode_transition_active && return 0
  mode="$(get_option @agents_sidebar_mode)"
  [[ "$mode" != 'compact' ]] || return 0

  window_id="${1:-$(current_window_id)}"
  [[ -n "$window_id" ]] || return 0
  window_exists "$window_id" || return 0

  window_name="$(tmux display-message -p -t "$window_id" '#{window_name}')"
  is_internal_window_name "$window_name" && return 0

  cleanup_duplicate_sidebar_panes "" "$window_id"
  window_has_internal_sidebar_panes "$window_id" && return 0

  pane_ids="$(managed_pane_ids_in_window "$window_id")"
  [[ -n "$pane_ids" ]] || return 0

  layout="$(window_layout_string "$window_id")"
  [[ -n "$layout" ]] || return 0
  active_pane="$(window_active_pane_id "$window_id")"

  set_option @agents_sidebar_wide_layout "$layout"
  set_option @agents_sidebar_wide_layout_panes "$pane_ids"
  set_option @agents_sidebar_wide_layout_active_pane "$active_pane"
  set_option @agents_sidebar_wide_layout_window "$window_id"
  set_option @agents_sidebar_wide_layout_saved_at "$(date +%s)"
  clear_wide_layout_dirty
}

saved_wide_layout_matches_current_panes() {
  local window_id="$1"
  local saved current
  saved="$(get_option @agents_sidebar_wide_layout_panes | tr ' ' '\n' | sed '/^$/d' | sort | paste -sd ' ' -)"
  current="$(managed_pane_ids_in_window "$window_id" | tr ' ' '\n' | sed '/^$/d' | sort | paste -sd ' ' -)"
  [[ -n "$saved" && "$saved" == "$current" ]]
}

auto_compact_token() {
  python3 - <<'PY'
import time
print(time.time_ns())
PY
}

schedule_auto_compact_run() {
  local token="$1"
  local client_tty="$2"

  nohup python3 - "$AUTO_COMPACT_DEBOUNCE_SECONDS" "$SESSION_ID" "$client_tty" "$SCRIPT_DIR/agents-sidebar" "$token" <<'PY' >/dev/null 2>&1 &
import os
import subprocess
import sys
import time

delay, session_id, client_tty, script_path, token = sys.argv[1:6]
time.sleep(float(delay))
env = os.environ.copy()
env["AGENTS_SIDEBAR_SESSION"] = session_id
env["AGENTS_SIDEBAR_CLIENT_TTY"] = client_tty
env.pop("AGENTS_SIDEBAR_PANE", None)
env.pop("TMUX", None)
subprocess.run(
    [script_path, "run-auto-compact", token],
    env=env,
    stdin=subprocess.DEVNULL,
    stdout=subprocess.DEVNULL,
    stderr=subprocess.DEVNULL,
    close_fds=True,
    check=False,
)
PY
}

store_session_name() {
  local session_key
  session_key="${SESSION_ID//[^[:alnum:]]/_}"
  echo "__agents_sidebar_store_${session_key}"
}

store_window_name() {
  echo "__agents_sidebar_store"
}

store_session_id() {
  get_option @agents_sidebar_store_session
}

store_window_id() {
  get_option @agents_sidebar_store_window
}

clear_store_state() {
  unset_option @agents_sidebar_store_session
  unset_option @agents_sidebar_store_window
}

kill_store_session() {
  local store_session store_name
  store_session="$(store_session_id)"
  if [[ -n "$store_session" ]] && session_exists "$store_session"; then
    tmux kill-session -t "$store_session" 2>/dev/null || true
  fi

  store_name="$(store_session_name)"
  tmux kill-session -t "$store_name" 2>/dev/null || true
  clear_store_state
}

ensure_store_window() {
  local start_path="${1:-$HOME}"
  local store_session store_window output placeholder store_name

  store_session="$(store_session_id)"
  store_window="$(store_window_id)"
  if [[ -n "$store_session" ]] && session_exists "$store_session" && [[ -n "$store_window" ]] && window_exists "$store_window"; then
    echo "$store_window"
    return 0
  fi

  kill_store_session
  store_name="$(store_session_name)"
  output="$(tmux new-session -d -P -F "#{session_id}${DELIM}#{window_id}${DELIM}#{pane_id}" -s "$store_name" -n "$(store_window_name)" -c "$start_path")"
  IFS="$DELIM" read -r store_session store_window placeholder <<<"$output"
  tmux set-option -w -t "$store_window" remain-on-exit off >/dev/null 2>&1 || true
  tmux select-pane -t "$placeholder" -T '__agents_sidebar_store_placeholder' >/dev/null 2>&1 || true
  set_option @agents_sidebar_store_session "$store_session"
  set_option @agents_sidebar_store_window "$store_window"
  echo "$store_window"
}

store_target_pane() {
  local store_window target_pane pane_id
  store_window="$(store_window_id)"
  if [[ -z "$store_window" ]] || ! window_exists "$store_window"; then
    store_window="$(ensure_store_window)"
  fi
  target_pane=""
  while IFS= read -r pane_id; do
    [[ -n "$target_pane" ]] || target_pane="$pane_id"
  done < <(tmux list-panes -t "$store_window" -F '#{pane_id}' 2>/dev/null || true)
  [[ -n "$target_pane" ]] || fail "store window has no target pane"
  echo "$target_pane"
}

REPAIR_LOCK_DIR=""
MODE_TRANSITION_LOCK_DIR=""
LAST_WIDE_TARGET_WINDOW=""

repair_lock_dir() {
  local session_key
  session_key="${SESSION_ID//[^[:alnum:]]/_}"
  echo "/tmp/agents-sidebar-repair-${session_key}.lock"
}

acquire_repair_lock() {
  REPAIR_LOCK_DIR="$(repair_lock_dir)"
  mkdir "$REPAIR_LOCK_DIR" 2>/dev/null
}

release_repair_lock() {
  if [[ -n "$REPAIR_LOCK_DIR" ]]; then
    rmdir "$REPAIR_LOCK_DIR" 2>/dev/null || true
    REPAIR_LOCK_DIR=""
  fi
}

mode_transition_lock_dir() {
  local session_key
  session_key="${SESSION_ID//[^[:alnum:]]/_}"
  echo "/tmp/agents-sidebar-mode-${session_key}.lock"
}

acquire_mode_transition_lock() {
  MODE_TRANSITION_LOCK_DIR="$(mode_transition_lock_dir)"
  mkdir "$MODE_TRANSITION_LOCK_DIR" 2>/dev/null
}

release_mode_transition_lock() {
  if [[ -n "$MODE_TRANSITION_LOCK_DIR" ]]; then
    rmdir "$MODE_TRANSITION_LOCK_DIR" 2>/dev/null || true
    MODE_TRANSITION_LOCK_DIR=""
  fi
}

begin_mode_transition() {
  set_option @agents_sidebar_transition 1
}

end_mode_transition() {
  unset_option @agents_sidebar_transition
}

mode_transition_active() {
  [[ "$(get_option @agents_sidebar_transition)" == "1" ]]
}

label_option_key() {
  local pane_id="$1"
  echo "@agents_sidebar_name_${pane_id#%}"
}

meta_option_key() {
  local pane_id="$1"
  local suffix="$2"
  echo "@agents_sidebar_${suffix}_${pane_id#%}"
}

metadata_cache_key() {
  local pane_id="$1"
  echo "${pane_id#%}"
}

load_session_metadata_cache() {
  local line name value key

  [[ "$SESSION_METADATA_CACHE_LOADED" == "1" ]] && return 0

  ENTRY_LABEL_CACHE=()
  ENTRY_LABEL_MODE_CACHE=()
  ENTRY_KIND_CACHE=()
  ENTRY_PROVIDER_CACHE=()
  ENTRY_STATUS_CACHE=()
  ENTRY_STATUS_TEXT_CACHE=()
  ENTRY_LAST_DONE_CACHE=()
  ENTRY_BRANCH_VALUE_CACHE=()
  ENTRY_BRANCH_PATH_CACHE=()
  ENTRY_BRANCH_CHECKED_CACHE=()

  while IFS= read -r line; do
    [[ "$line" == @agents_sidebar_* ]] || continue
    name="${line%% *}"
    value="${line#"$name"}"
    value="${value# }"
    case "$name" in
      @agents_sidebar_name_*)
        key="${name#@agents_sidebar_name_}"
        ENTRY_LABEL_CACHE["$key"]="$value"
        ;;
      @agents_sidebar_label_mode_*)
        key="${name#@agents_sidebar_label_mode_}"
        ENTRY_LABEL_MODE_CACHE["$key"]="$value"
        ;;
      @agents_sidebar_kind_*)
        key="${name#@agents_sidebar_kind_}"
        ENTRY_KIND_CACHE["$key"]="$value"
        ;;
      @agents_sidebar_provider_*)
        key="${name#@agents_sidebar_provider_}"
        ENTRY_PROVIDER_CACHE["$key"]="$value"
        ;;
      @agents_sidebar_status_text_*)
        key="${name#@agents_sidebar_status_text_}"
        ENTRY_STATUS_TEXT_CACHE["$key"]="$value"
        ;;
      @agents_sidebar_status_*)
        key="${name#@agents_sidebar_status_}"
        ENTRY_STATUS_CACHE["$key"]="$value"
        ;;
      @agents_sidebar_last_done_*)
        key="${name#@agents_sidebar_last_done_}"
        ENTRY_LAST_DONE_CACHE["$key"]="$value"
        ;;
      @agents_sidebar_branch_path_*)
        key="${name#@agents_sidebar_branch_path_}"
        ENTRY_BRANCH_PATH_CACHE["$key"]="$value"
        ;;
      @agents_sidebar_branch_checked_*)
        key="${name#@agents_sidebar_branch_checked_}"
        ENTRY_BRANCH_CHECKED_CACHE["$key"]="$value"
        ;;
      @agents_sidebar_branch_*)
        key="${name#@agents_sidebar_branch_}"
        ENTRY_BRANCH_VALUE_CACHE["$key"]="$value"
        ;;
    esac
  done < <(tmux show-options -t "$SESSION_ID" 2>/dev/null || true)

  SESSION_METADATA_CACHE_LOADED=1
}

stored_entry_label() {
  local pane_id="$1"
  local key
  key="$(metadata_cache_key "$pane_id")"
  load_session_metadata_cache
  echo "${ENTRY_LABEL_CACHE[$key]:-}"
}

remember_entry_label() {
  local pane_id="$1"
  local label="$2"
  local key
  [[ -n "$pane_id" && -n "$label" ]] || return 0
  key="$(metadata_cache_key "$pane_id")"
  set_option "$(label_option_key "$pane_id")" "$label"
  ENTRY_LABEL_CACHE["$key"]="$label"
  SESSION_METADATA_CACHE_LOADED=1
}

clear_entry_label() {
  local pane_id="$1"
  local key
  key="$(metadata_cache_key "$pane_id")"
  unset_option "$(label_option_key "$pane_id")"
  unset "ENTRY_LABEL_CACHE[$key]"
  SESSION_METADATA_CACHE_LOADED=1
}

stored_entry_label_mode() {
  local pane_id="$1"
  local key
  key="$(metadata_cache_key "$pane_id")"
  load_session_metadata_cache
  echo "${ENTRY_LABEL_MODE_CACHE[$key]:-auto}"
}


  local key
  [[ -n "$pane_id" ]] || return 0
  key="$(metadata_cache_key "$pane_id")"
  if [[ -n "$status" ]]; then
    set_option "$(meta_option_key "$pane_id" status)" "$status"
    ENTRY_STATUS_CACHE["$key"]="$status"
  else

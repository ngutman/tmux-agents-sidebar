  if [[ -n "$mode" ]]; then
    set_option "$(meta_option_key "$pane_id" label_mode)" "$mode"
    ENTRY_LABEL_MODE_CACHE["$key"]="$mode"
  else
    unset_option "$(meta_option_key "$pane_id" label_mode)"
    unset "ENTRY_LABEL_MODE_CACHE[$key]"
  fi
  SESSION_METADATA_CACHE_LOADED=1
}

